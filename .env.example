# Copy to `.env` in the project root (Vite reads `VITE_*` at build/dev time).
# Optional: improves OpenWeatherMap merge when set.
VITE_OPENWEATHERMAP_API_KEY=

# Optional: appended to NWS User-Agent (api.weather.gov) for support / heavy use.
VITE_NWS_CONTACT_EMAIL=

# Optional: ArcGIS API key if you add private layers or higher quotas later.
# Public WebScene in this app does not require it.
VITE_ARCGIS_API_KEY=
